# Firebase web app config — copy this file to `.env` and fill in your values.
# Find these in Firebase console → Project settings → Your apps → Web app → SDK setup.
# All values are exposed to the browser (that is normal for Firebase web configs);
# access is controlled by the Realtime Database security rules, not by hiding these.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
