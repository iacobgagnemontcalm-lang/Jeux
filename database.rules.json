{
  "rules": {
    ".read": false,
    ".write": false,
    "sessions": {
      "$pin": {
        ".read": "auth != null",
        "status": {
          ".write": "auth != null",
          ".validate": "newData.isString() && (newData.val() == 'lobby' || newData.val() == 'playing' || newData.val() == 'ended')"
        },
        "hostId": {
          ".write": "auth != null && newData.val() == auth.uid",
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".write": "auth != null",
          ".validate": "newData.isNumber()"
        },
        "startedAt": {
          ".write": "auth != null",
          ".validate": "newData.isNumber() || newData.val() == null"
        },
        "endsAt": {
          ".write": "auth != null",
          ".validate": "newData.isNumber() || newData.val() == null"
        },
        "players": {
          "$playerId": {
            ".write": "auth != null && auth.uid == $playerId",
            "name": { ".validate": "newData.isString() && newData.val().length <= 30" },
            "points": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "comboStreak": { ".validate": "newData.isNumber()" },
            "lastFruit": { ".validate": "newData.isString() || newData.val() == null" },
            "joinedAt": { ".validate": "newData.isNumber()" },
            "fruitCounts": {
              "$fruit": { ".validate": "newData.isNumber()" }
            }
          }
        },
        "usedCodes": {
          "$code": {
            ".write": "auth != null && !data.exists()",
            ".validate": "newData.isString() && newData.val().length <= 64"
          }
        }
      }
    },
    "wheelSessions": {
      "$pin": {
        ".read": "auth != null",
        "status": {
          ".write": "auth != null",
          ".validate": "newData.isString() && (newData.val() == 'lobby' || newData.val() == 'playing' || newData.val() == 'ended')"
        },
        "hostId": {
          ".write": "auth != null && newData.val() == auth.uid",
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".write": "auth != null",
          ".validate": "newData.isNumber()"
        },
        "startedAt": {
          ".write": "auth != null",
          ".validate": "newData.isNumber() || newData.val() == null"
        },
        "difficulty": {
          ".write": "auth != null",
          ".validate": "newData.isString() && (newData.val() == 'easy' || newData.val() == 'medium' || newData.val() == 'hard' || newData.val() == 'extra' || newData.val() == 'expert')"
        },
        "mode": {
          ".write": "auth != null",
          ".validate": "newData.isString() && (newData.val() == 'shared' || newData.val() == 'solo')"
        },
        "era": {
          ".write": "auth != null",
          ".validate": "newData.isString() && (newData.val() == 'current' || newData.val() == 'historical')"
        },
        "yearFrom": {
          ".write": "auth != null",
          ".validate": "newData.isNumber() && newData.val() >= 1980 && newData.val() <= 2100"
        },
        "yearTo": {
          ".write": "auth != null",
          ".validate": "newData.isNumber() && newData.val() >= 1980 && newData.val() <= 2100"
        },
        "order": {
          ".write": "auth != null",
          "$i": { ".validate": "newData.isString()" }
        },
        "turnIndex": {
          ".write": "auth != null",
          ".validate": "newData.isNumber()"
        },
        "spin": {
          ".write": "auth != null",
          "team": { ".validate": "newData.isString() && newData.val().length <= 4" },
          "year": { ".validate": "newData.isNumber() && newData.val() >= 1980 && newData.val() <= 2100" },
          "by": { ".validate": "newData.isString()" },
          "nonce": { ".validate": "newData.isNumber()" },
          "at": { ".validate": "newData.isNumber()" }
        },
        "usedTeams": {
          "$team": {
            ".write": "auth != null && !data.exists()",
            ".validate": "newData.isString()"
          }
        },
        "players": {
          "$playerId": {
            ".write": "auth != null && (auth.uid == $playerId || $playerId.beginsWith('bot_'))",
            "name": { ".validate": "newData.isString() && newData.val().length <= 30" },
            "joinedAt": { ".validate": "newData.isNumber()" },
            "bot": { ".validate": "newData.isString() && (newData.val() == 'noob' || newData.val() == 'connaisseur' || newData.val() == 'expert')" },
            "roster": {
              "$slot": {
                ".validate": "$slot == 'QB' || $slot == 'RB1' || $slot == 'RB2' || $slot == 'WR1' || $slot == 'WR2' || $slot == 'TE' || $slot == 'FLEX' || $slot == 'K' || $slot == 'DEF'",
                "id": { ".validate": "newData.isString() && newData.val().length <= 24" },
                "name": { ".validate": "newData.isString() && newData.val().length <= 60" },
                "pos": { ".validate": "newData.isString() && newData.val().length <= 4" },
                "team": { ".validate": "newData.isString() && newData.val().length <= 4" },
                "year": { ".validate": "newData.isNumber() && newData.val() >= 1980 && newData.val() <= 2100" },
                "pts": { ".validate": "newData.isNumber()" },
                "bonus": { ".validate": "newData.isBoolean()" }
              }
            }
          }
        }
      }
    },
    "wheelBests": {
      ".read": "auth != null",
      "$nameKey": {
        ".write": "auth != null && (!data.exists() || newData.child('score').val() > data.child('score').val())",
        ".validate": "newData.hasChildren(['name', 'score', 'at'])",
        "name": { ".validate": "newData.isString() && newData.val().length <= 30" },
        "score": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "at": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    }
  }
}
